# Supabase 配置（必须）
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 邮箱验证码后端（推荐：腾讯云 SCF / 任意后端）
# 说明：不要把邮箱 SMTP 授权码放到 VITE_ 变量里（会打包到前端，等于泄露）
# 例：https://service-xxxx-12345.apigw.tencentcs.com/release
VITE_VERIFICATION_API_BASE_URL=

# 大模型 API 配置（用于 OCR 识别）
VITE_LLM_API_KEY=your_llm_api_key

# DeepSeek API Key（用于 AI 评分）
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key
