# SQLite
APP_DB_PATH=./data/app.db

# Admin Panel (/admin)
# 生产环境务必改强密码；如不需要可设 ADMIN_ENABLED=0
ADMIN_ENABLED=1
ADMIN_USER=admin
ADMIN_PASSWORD=change_me
ADMIN_SECRET_KEY=change_me_to_a_long_random_string

# 163 SMTP（必须使用“客户端授权码/SMTP 授权码”，不是登录密码）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@163.com
SMTP_PASS=your_smtp_auth_code
SMTP_FROM=your@163.com

# LLM（OpenAI 兼容 API）
# 建议带 /v1；即使不带，后端也会自动补上（但推荐显式配置更清晰）。
LLM_BASE_URL=https://llm.xiaochisaas.com/v1
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
GRADE_LLM_MODEL=claude-sonnet-4-6
LLM_DEBUG=0

# 开发调试（生产不要开）
SMTP_DISABLED=0
DEV_RETURN_CODE=0
SMTP_DEBUG=0
SMTP_DEBUG_ENDPOINT=0

# OCR（大模型识图）压缩参数（避免上游 413）
OCR_IMAGE_MAX_BYTES=600000
OCR_IMAGE_MAX_DIM=1280
OCR_DEBUG=0
OCR_LLM_MODEL=gemini-3-flash
# 可选：如果 OCR_LLM_MODEL 不支持图片输入，可设置图片模型兜底
OCR_FALLBACK_LLM_MODEL=gemini-3-pro-image
